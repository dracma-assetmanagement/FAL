<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dracma — Fondo de Asistencia Laboral</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --navy:#0D1B2A;
  --deep:#1B2838;
  --slate:#243447;
  --blue:#1565C0;
  --cyan:#00ACC1;
  --cyan-soft:#4DD0E1;
  --ice:#E0F7FA;
  --mint:#B2EBF2;
  --ghost:#F4F7FA;
  --text:#14253D;
  --body:#475B74;
  --muted:#8498B1;
  --white:#fff;
}
html{scroll-behavior:smooth}
body{
  font-family:'Montserrat',sans-serif;
  color:var(--body);
  background:var(--ghost);
  line-height:1.6;
  -webkit-font-smoothing:antialiased;
}

/* ── NAV ── */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  background:rgba(13,27,42,0.92);
  backdrop-filter:blur(20px);
  border-bottom:1px solid rgba(0,172,193,0.15);
  padding:0 48px;height:64px;
  display:flex;align-items:center;justify-content:space-between;
}
.nav__logo{height:32px;object-fit:contain;filter:brightness(0) invert(1);opacity:0.95}
.nav__links{display:flex;gap:28px;align-items:center}
.nav__links a{
  font-size:12.5px;font-weight:500;color:rgba(255,255,255,0.7);
  text-decoration:none;letter-spacing:0.3px;transition:color .25s;
}
.nav__links a:hover{color:var(--cyan-soft)}
.nav__cta{
  font-size:12px;font-weight:600;color:var(--white);
  background:linear-gradient(135deg,var(--cyan),var(--blue));
  padding:8px 22px;border-radius:8px;text-decoration:none;
  transition:transform .2s,box-shadow .2s;
}
.nav__cta:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(0,172,193,0.35)}

/* ── HERO ── */
.hero{
  position:relative;min-height:100vh;
  display:flex;align-items:center;overflow:hidden;background:var(--navy);
}
.hero__bg{
  position:absolute;inset:0;width:100%;height:100%;object-fit:cover;
  opacity:0.2;filter:saturate(0.5) brightness(0.8);
}
.hero__gradient{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 80% 60% at 20% 50%,rgba(13,27,42,0.95) 0%,transparent 70%),
    radial-gradient(ellipse 50% 80% at 80% 80%,rgba(0,172,193,0.10) 0%,transparent 60%),
    linear-gradient(180deg,rgba(13,27,42,0.7) 0%,rgba(13,27,42,0.4) 100%);
}
.hero__content{
  position:relative;z-index:2;max-width:1200px;margin:0 auto;
  padding:120px 48px 80px;
  display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;width:100%;
}
.hero__text{max-width:520px}
.hero__badge{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(0,172,193,0.12);border:1px solid rgba(0,172,193,0.25);
  border-radius:100px;padding:6px 16px;
  font-size:11px;font-weight:600;color:var(--cyan-soft);
  text-transform:uppercase;letter-spacing:2px;margin-bottom:24px;
}
.hero__badge::before{
  content:'';width:6px;height:6px;border-radius:50%;background:var(--cyan);
  animation:pulse 2s ease infinite;
}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}
.hero__h1{
  font-size:50px;font-weight:800;color:var(--white);
  line-height:1.08;letter-spacing:-1px;margin-bottom:20px;
}
.hero__h1 em{
  font-style:normal;
  background:linear-gradient(135deg,var(--cyan-soft),var(--cyan));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.hero__sub{
  font-size:15.5px;font-weight:400;color:rgba(255,255,255,0.6);
  line-height:1.7;max-width:460px;margin-bottom:36px;
}
.hero__actions{display:flex;gap:14px;flex-wrap:wrap}
.btn{
  display:inline-flex;align-items:center;gap:8px;
  padding:14px 28px;border-radius:10px;
  font-family:'Montserrat',sans-serif;font-size:14px;font-weight:600;
  text-decoration:none;transition:all .25s;cursor:pointer;border:none;
}
.btn--primary{
  background:linear-gradient(135deg,var(--cyan),var(--blue));color:var(--white);
  box-shadow:0 4px 24px rgba(0,172,193,0.3);
}
.btn--primary:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(0,172,193,0.4)}
.btn--ghost{
  background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.15);color:var(--white);
}
.btn--ghost:hover{background:rgba(255,255,255,0.12);border-color:rgba(255,255,255,0.3)}

/* Hero card */
.hero__visual{display:flex;justify-content:center;align-items:center}
.hero__card{
  background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);
  backdrop-filter:blur(30px);border-radius:20px;padding:36px;width:100%;max-width:420px;
}
.hero__card h3{
  font-size:12px;font-weight:700;color:var(--cyan-soft);
  text-transform:uppercase;letter-spacing:2px;margin-bottom:20px;
}
.rate-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.rate-box{
  background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);
  border-radius:12px;padding:20px;text-align:center;transition:border-color .3s;
}
.rate-box:hover{border-color:rgba(0,172,193,0.4)}
.rate-box__label{font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px}
.rate-box__num{font-size:36px;font-weight:800;color:var(--white);line-height:1}
.rate-box__unit{font-size:10px;font-weight:400;color:rgba(255,255,255,0.45);margin-top:4px}
.hero__card .card-note{
  font-size:11px;color:rgba(255,255,255,0.4);margin-top:16px;line-height:1.6;
  padding-top:16px;border-top:1px solid rgba(255,255,255,0.06);
}

/* ── SECTIONS ── */
section{padding:80px 48px}
.container{max-width:1100px;margin:0 auto}
.section-label{
  font-size:11px;font-weight:700;color:var(--cyan);
  text-transform:uppercase;letter-spacing:3px;margin-bottom:12px;
}
.section-title{
  font-size:32px;font-weight:800;color:var(--text);
  line-height:1.15;letter-spacing:-0.5px;margin-bottom:16px;
}
.section-desc{font-size:15px;color:var(--body);max-width:620px;line-height:1.7;margin-bottom:40px}

/* ── QUE ES ── */
.what{background:var(--white)}
.what__grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start}
.what__left p{font-size:14px;line-height:1.8;margin-bottom:14px}
.what__left p strong{color:var(--text);font-weight:600}
.law-tag{
  display:inline-flex;align-items:center;gap:6px;
  background:var(--ice);border-radius:8px;padding:8px 14px;
  font-size:12px;font-weight:600;color:var(--blue);margin-top:10px;
}
.what__right{
  background:var(--ghost);border-radius:16px;padding:32px;border-left:4px solid var(--cyan);
}
.what__right h3{
  font-size:11px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:2px;margin-bottom:10px;
}
.what__right p{font-size:13px;line-height:1.75;color:var(--body)}

/* ── BENEFICIOS ── */
.benefits{background:var(--ghost)}
.benefits__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.b-card{
  background:var(--white);border-radius:16px;padding:28px 24px;
  border:1px solid #E8EDF2;transition:transform .3s,box-shadow .3s,border-color .3s;
}
.b-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(0,0,0,0.06);border-color:var(--cyan)}
.b-card__icon{
  width:44px;height:44px;border-radius:12px;
  background:linear-gradient(135deg,var(--ice),var(--mint));
  display:flex;align-items:center;justify-content:center;margin-bottom:16px;
}
.b-card__icon svg{width:22px;height:22px;stroke:var(--cyan);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.b-card h4{font-size:14px;font-weight:700;color:var(--text);margin-bottom:8px;line-height:1.3}
.b-card p{font-size:12.5px;color:var(--body);line-height:1.65}

/* ── ADMIN ── */
.admin{background:var(--navy);position:relative;overflow:hidden}
.admin::before{
  content:'';position:absolute;width:500px;height:500px;border-radius:50%;
  background:radial-gradient(circle,rgba(0,172,193,0.08) 0%,transparent 70%);
  top:-200px;right:-100px;
}
.admin .container{position:relative;z-index:2}
.admin .section-label{color:var(--cyan-soft)}
.admin .section-title{color:var(--white)}
.admin .section-desc{color:rgba(255,255,255,0.55)}
.admin__row{display:grid;grid-template-columns:1.2fr 1fr;gap:40px;align-items:center}
.admin__text p{font-size:14px;color:rgba(255,255,255,0.6);line-height:1.75}
.admin__cards{display:flex;flex-direction:column;gap:14px}
.admin-card{
  display:flex;align-items:center;gap:16px;
  background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);
  border-radius:14px;padding:20px 24px;transition:border-color .3s,background .3s;
}
.admin-card:hover{border-color:rgba(0,172,193,0.4);background:rgba(0,172,193,0.06)}
.admin-card__num{
  font-size:28px;font-weight:800;
  background:linear-gradient(135deg,var(--cyan-soft),var(--cyan));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;
}
.admin-card__label{font-size:14px;font-weight:600;color:var(--white)}
.admin-card__sub{font-size:11px;color:rgba(255,255,255,0.4);margin-top:2px}

/* ── VIGENCIA STRIP ── */
.vigencia-strip{
  background:linear-gradient(135deg,var(--cyan),var(--blue));
  padding:28px 48px;display:flex;align-items:center;justify-content:center;gap:40px;flex-wrap:wrap;
}
.vigencia-strip__text{font-size:18px;font-weight:700;color:var(--white)}
.vigencia-strip__text span{font-weight:400;opacity:0.8;font-size:14px;margin-left:8px}
.vigencia-strip .btn{
  background:var(--white);color:var(--blue);font-weight:700;
  box-shadow:0 4px 16px rgba(0,0,0,0.15);
}
.vigencia-strip .btn:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,0.2)}

/* ── FOOTER ── */
.footer{
  background:var(--navy);padding:28px 48px;
  display:flex;justify-content:space-between;align-items:center;gap:32px;flex-wrap:wrap;
  border-top:1px solid rgba(255,255,255,0.06);
}
.footer__left{flex:1;min-width:300px}
.footer__disclaimer{font-size:10px;color:rgba(255,255,255,0.3);line-height:1.7}
.footer__right{text-align:right}
.footer__right a{font-size:12px;color:var(--cyan-soft);text-decoration:none;font-weight:500}
.footer__right p{font-size:10px;color:rgba(255,255,255,0.35);margin-top:4px}

@keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
.hero__text{animation:fadeUp .8s ease both}
.hero__visual{animation:fadeUp .8s ease .2s both}
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <img class="nav__logo" src="data:image/png;base64," alt="Dracma">
  <div class="nav__links">
    <a href="#regimen">El régimen</a>
    <a href="#beneficios">Beneficios</a>
    <a href="#dracma">Dracma AM</a>
    <a href="#contacto" class="nav__cta">Consultá a tu asesor</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <img class="hero__bg" src="data:image/png;base64," alt="">
  <div class="hero__gradient"></div>
  <div class="hero__content">
    <div class="hero__text">
      <div class="hero__badge">Nuevo régimen · Sector privado</div>
      <h1 class="hero__h1">Fondo de<br>Asistencia<br><em>Laboral | FAL</em></h1>
      <p class="hero__sub">El FAL es un fondo destinado exclusivamente a asistir el pago de indemnizaciones laborales — preaviso, integración y despido — por parte de los empleadores del Sector Privado.</p>
      <div class="hero__actions">
        <a href="#dracma" class="btn btn--primary">Dracma como administrador</a>
        <a href="#regimen" class="btn btn--ghost">Ver más ↓</a>
      </div>
    </div>
    <div class="hero__visual">
      <div class="hero__card">
        <h3>Contribuciones mensuales</h3>
        <div class="rate-grid">
          <div class="rate-box">
            <div class="rate-box__label">Micro & PyMEs</div>
            <div class="rate-box__num">2,5%</div>
            <div class="rate-box__unit">de las remuneraciones</div>
          </div>
          <div class="rate-box">
            <div class="rate-box__label">Grandes empresas</div>
            <div class="rate-box__num">1%</div>
            <div class="rate-box__unit">de las remuneraciones</div>
          </div>
        </div>
        <p class="card-note">Las cuentas del FAL se integran con una contribución mensual calculada sobre las remuneraciones base para las contribuciones patronales al SIPA.</p>
      </div>
    </div>
  </div>
</section>

<!-- RÉGIMEN -->
<section class="what" id="regimen">
  <div class="container">
    <div class="what__grid">
      <div class="what__left">
        <p class="section-label">Marco normativo</p>
        <h2 class="section-title">Régimen para empleadores del sector privado</h2>
        <p>El FAL surge a partir de la <strong>Ley 27.802 de Modernización Laboral</strong>, sancionada el 27 de febrero de 2026 y promulgada el 6 de marzo de 2026 (artículos 58 al 77).</p>
        <p>Este esquema establece que los empleadores del sector privado deberán constituir un fondo mediante <strong>contribuciones mensuales obligatorias</strong>.</p>
        <p>Las sumas serán ingresadas al FAL mensualmente junto con los aportes y contribuciones patronales y <strong>no implicarán un aumento</strong> en las contribuciones del empleador.</p>
        <div class="law-tag">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Ley 27.802 · Arts. 58 al 77
        </div>
      </div>
      <div class="what__right">
        <h3>¿Cómo funciona?</h3>
        <p>Las cuentas del FAL se integran con una contribución mensual calculada sobre las remuneraciones que sirven de base para las contribuciones patronales al <strong>SIPA</strong>.</p>
        <br>
        <p><strong>Micro y PYMES:</strong> 2,5% de las remuneraciones.</p>
        <p><strong>Grandes empresas:</strong> 1% de las remuneraciones.</p>
        <br>
        <p>Las sumas serán ingresadas al FAL mensualmente junto con los aportes y contribuciones patronales y no implicarán un aumento en las contribuciones del empleador.</p>
      </div>
    </div>
  </div>
</section>

<!-- BENEFICIOS -->
<section class="benefits" id="beneficios">
  <div class="container">
    <p class="section-label">Esquema</p>
    <h2 class="section-title">Características y beneficios</h2>
    <p class="section-desc">Principales aspectos del Fondo de Asistencia Laboral según lo establecido en la Ley 27.802.</p>
    <div class="benefits__grid">
      <div class="b-card">
        <div class="b-card__icon">
          <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h4>Fondo de objeto específico e inembargable</h4>
        <p>Los aportes se acumulan en una cuenta destinada exclusivamente a asistir al pago de indemnizaciones. El patrimonio del fondo es independiente e inembargable.</p>
      </div>
      <div class="b-card">
        <div class="b-card__icon">
          <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h4>Administración profesional</h4>
        <p>Los fondos serán administrados por entidades habilitadas a tal fin por la Comisión Nacional de Valores (CNV).</p>
      </div>
      <div class="b-card">
        <div class="b-card__icon">
          <svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        </div>
        <h4>Control del empleador sobre los pagos</h4>
        <p>La empresa decide cuándo y en qué proporción utilizar los recursos del fondo para cumplir con las indemnizaciones correspondientes. La existencia del FAL no modifica, sustituye, ni altera el régimen indemnizatorio.</p>
      </div>
      <div class="b-card">
        <div class="b-card__icon">
          <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <h4>Tratamiento impositivo favorable</h4>
        <p>Las contribuciones al fondo y los resultados de la inversión se encuentran exentos del Impuesto a las Ganancias y de IVA.</p>
      </div>
      <div class="b-card">
        <div class="b-card__icon">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h4>Posibilidad de suspender contribuciones al fondo</h4>
        <p>Si el saldo acumulado del fondo alcanza los niveles que determine la reglamentación, el empleador podrá solicitar la interrupción o suspensión de las contribuciones mensuales.</p>
      </div>
      <div class="b-card">
        <div class="b-card__icon">
          <svg viewBox="0 0 24 24"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
        </div>
        <h4>Sin incremento en las cargas</h4>
        <p>Las sumas serán ingresadas al FAL mensualmente junto con los aportes y contribuciones patronales y no implicarán un aumento en las contribuciones del empleador.</p>
      </div>
    </div>
  </div>
</section>

<!-- ADMIN -->
<section class="admin" id="dracma">
  <div class="container">
    <p class="section-label">Tu administrador</p>
    <h2 class="section-title">Dracma Asset Management como administrador de FAL</h2>
    <p class="section-desc">En Dracma Sociedad Gerente de Fondos Comunes de Inversión S.A.U., entidad habilitada por CNV, estaremos participando como administradores de Fondos de Asistencia Laboral, acompañando a las empresas en:</p>
    <div class="admin__row">
      <div class="admin__text">
        <p>Dracma Asset Management pone a disposición su estructura y equipo profesional para gestionar tu Fondo de Asistencia Laboral, brindándote acompañamiento integral desde la apertura hasta la administración continua de tu cuenta.</p>
      </div>
      <div class="admin__cards">
        <div class="admin-card">
          <div class="admin-card__num">01</div>
          <div>
            <div class="admin-card__label">Administración del fondo</div>
            <div class="admin-card__sub">Apertura, operatoria y seguimiento</div>
          </div>
        </div>
        <div class="admin-card">
          <div class="admin-card__num">02</div>
          <div>
            <div class="admin-card__label">Gestión profesional de las inversiones</div>
            <div class="admin-card__sub">Estrategia y rendimiento del capital</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- VIGENCIA + CONTACTO -->
<div class="vigencia-strip" id="contacto">
  <div class="vigencia-strip__text">
    Vigencia: 1 de junio de 2026 <span>· Sujeto a reglamentación</span>
  </div>
  <button class="btn" onclick="document.getElementById('contactModal').style.display='flex'">Consultá a tu asesor para conocer más sobre el FAL →</button>
</div>

<!-- MODAL -->
<div id="contactModal" style="display:none;position:fixed;inset:0;z-index:999;background:rgba(0,0,0,0.6);backdrop-filter:blur(8px);align-items:center;justify-content:center;" onclick="if(event.target===this)this.style.display='none'">
  <div style="background:var(--navy);border:1px solid rgba(0,172,193,0.2);border-radius:20px;padding:40px;max-width:420px;width:90%;position:relative;">
    <button onclick="document.getElementById('contactModal').style.display='none'" style="position:absolute;top:16px;right:20px;background:none;border:none;color:var(--muted);font-size:22px;cursor:pointer;font-family:Montserrat;">&times;</button>
    <p style="font-size:11px;font-weight:700;color:var(--cyan-soft);text-transform:uppercase;letter-spacing:2px;margin-bottom:20px;">Contactanos</p>
    <h3 style="font-size:22px;font-weight:800;color:var(--white);margin-bottom:28px;line-height:1.2;">Hablá con nuestro equipo</h3>

    <!-- Card Agustín -->
    <div style="display:flex;align-items:center;gap:16px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:14px;padding:18px 20px;margin-bottom:12px;">
      <div style="width:46px;height:46px;border-radius:50%;background:linear-gradient(135deg,var(--cyan),var(--blue));display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <span style="font-size:18px;font-weight:800;color:var(--white);">AM</span>
